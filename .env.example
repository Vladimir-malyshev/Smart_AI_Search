### Core Services ###
# URL для подключения к Redis (хранение состояний и карантина)
REDIS_URL=redis://localhost:6379/0
# Внутренний API ключ приложения
API_KEY=your_api_key_here

### Provider API Keys ###
# Ключ от Google Gemini (или совместимого API)
GEMINI_API_KEY=your_gemini_api_key_here
# Ключ от Jina.ai (используется для s.jina.ai и r.jina.ai)
JINA_API_KEY=your_jina_api_key_here
# Ключ от OpenAI (если используется OpenAI)
# OPENAI_API_KEY=
# Базовый URL для OpenAI-совместимых API (например, vLLM или Ollama)
# OPENAI_BASE_URL=

### Master Orchestrator ###
# Максимальное количество итераций пайплайна (исследовательских циклов)
MAX_ITERATIONS=3
# Общий таймаут на весь запрос пользователя (в секундах)
GLOBAL_TIMEOUT_SEC=200.0

### Search Provider ###
# Какой поисковый провайдер использовать (jina, searxng, tavily)
SEARCH_PROVIDER=jina

### LLM Configurations ###
# Глобальный провайдер LLM (gemini, openai)
LLM_PROVIDER=gemini
# Модель для модуля оценки сниппетов (Snippet Evaluator)
EVALUATOR_LLM_MODEL=gemma-3-27b-it
# Модель для финального ответа и синтеза (AI Judge)
JUDGE_LLM_MODEL=gemini-3.1-flash-lite-preview
# Модель для OpenAI-провайдера
# OPENAI_MODEL=gpt-4o
# Модель для Gemini-провайдера (используется по умолчанию в Query Expansion)
# GEMINI_MODEL=gemma-3-27b-it

# Настройки повторных запросов к LLM (при ошибке 429 RESOURCE_EXHAUSTED)
LLM_MAX_RETRIES=4
# Пауза между повторными попытками (в секундах)
LLM_RETRY_DELAY_SEC=30.0

### AI Judge context truncation ###
# Максимальное количество символов из одного источника (URL), передаваемых Судье
JUDGE_MAX_CHARS_PER_SOURCE=6000

### Snippet Evaluator ###
# Максимальное количество URL, отбираемых за одну итерацию
EVALUATOR_MAX_SELECTED=4
# Минимальное необходимое количество URL для продолжения сбора
EVALUATOR_MIN_SELECTED=1

### Query Expansion ###
# Максимальное количество слов в одном поисковом запросе
QUERY_MAX_WORDS=10
# Минимальное количество сгенерированных поисковых запросов
QUERY_MIN_COUNT=2
# Максимальное количество сгенерированных поисковых запросов за раз
QUERY_MAX_COUNT=5

### Jina Reader Settings ###
# Максимальное количество символов, извлекаемых со страницы (защита контекста)
JINA_MAX_CHARS=20000
# Таймаут на фронтенд-загрузку и чтение одной страницы (в секундах)
JINA_TIMEOUT_SEC=15.0
# Количество одновременных парлельных загрузок страниц
JINA_CONCURRENCY=4
# Удалять ли оверлеи, cookie-баннеры и поп-апы (true/false)
JINA_REMOVE_OVERLAY=true
# Финансовый лимит токенов на запрос к Jina Reader (опционально)
JINA_TOKEN_BUDGET=
# Локаль браузера при серверном рендеринге Jina (опционально)
JINA_LOCALE=
# Когда Jina обрывает ожидание загрузки SPA (network-idle, html и др.)
JINA_RESPOND_TIMING=network-idle
# CSS селекторы блоков, которые Jina вырежет перед возвратом HTML -> Markdown
JINA_REMOVE_SELECTOR="header, footer, nav, aside, .sidebar, .comments, #comments, .advertisement, .nav, .menu"

### Jina Search Settings ###
# Поисковый движок под капотом s.jina.ai (google, bing)
JINA_SEARCH_ENGINE=google
# Количество результатов, запрашиваемых у поиска
JINA_SEARCH_NUM_RESULTS=5
# Локаль поисковика (опционально, например ru)
JINA_SEARCH_LOCALE=
# Гео-локаль поиска (опционально, например ru)
JINA_SEARCH_COUNTRY=
# Отключать ли авто-исправление опечаток поисковиком — No Fix Phrase (true/false)
JINA_SEARCH_NO_FIX_PHRASE=true
# Домены, исключаемые клиентом из результатов (соцсети, агрегаторы)
JINA_SEARCH_EXCLUDE_DOMAINS="twitter.com,x.com,facebook.com,instagram.com,t.me,vk.com"

### Harvester Tuning ###
# Интервал обновления пула поисковых нод (в секундах)
HARVESTER_INTERVAL_SEC=3600
# Таймаут при пингах (проверке доступности) отдельной ноды (в секундах)
HEALTH_CHECK_TIMEOUT_SEC=8.0
# Количество одновременных пингов нод (параллелизм)
HEALTH_CHECK_CONCURRENCY=5

### Fallback Nodes (запятая как разделитель) ###
# Статические резервные ноды SearXNG, если база пуста
STATIC_NODES=https://baresearch.org,https://paulgo.io,https://priv.au
# Использовать ли Bootstrap-ноды по умолчанию
USE_BOOTSTRAP_NODES=True
